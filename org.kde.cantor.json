{
    "id": "org.kde.cantor",
    "runtime": "org.kde.Platform",
    "runtime-version": "5.15-22.08",
    "base": "io.qt.qtwebengine.BaseApp",
    "base-version": "5.15-22.08",
    "sdk": "org.kde.Sdk",
    "command": "cantor",
    "rename-icon": "cantor",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=xdg-documents",
        "--device=dri",
        "--socket=pulseaudio",
        "--share=network",
        "--filesystem=home",
        "--talk-name=com.canonical.AppMenu.Registrar",
        "--talk-name=org.freedesktop.Flatpak",
        "--env=PATH=/app/bin:/usr/bin:/app/jre/bin",
        "--env=CPPFLAGS=-I/app/include",
        "--env=LDFLAGS=-L/app/lib",
        "--env=LD_LIBRARY_PATH=/app/lib",
        "--env=OCTAVE_HOME=/app",
        "--env=PKG_CONFIG_PATH=/app/lib/pkgconfig:/app/share/pkgconfig"
    ],
    "modules": [
        "shared-modules/glu/glu-9.json",
        "python3-requirements.json",
        "poppler.json",
        "analitza.json",
        "octave.json",
        "scilab.json",
        "maxima.json",
        {
            "name": "cantor",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/23.08.2/src/cantor-23.08.2.tar.xz",
                    "sha256": "1cc1f68ad6277bbb22472bdf868966506a02098f0100ec1bfb0e0f88b31fb961",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/cantor-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
